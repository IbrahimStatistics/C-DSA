#include<stdio.h>
#include<stdlib.h>

typedef struct Node {
    int data;
    struct Node *next;
}Node;

typedef struct Stack {
    Node *top;
    int getSize;
}Stack;

void initStack(Stack *S) {
    S->top = NULL;
    S->getSize = 0;
}

Node* createNode(int val) {
    Node *newNode = (Node *)malloc(sizeof(Node));
    
    if(newNode == NULL) {
        printf("Memory allocation failed\n");
        return NULL;
    }

    newNode->data = val;
    newNode->next = NULL;

    return newNode;
}

void printStack(Stack *S) {
    if(S->top == NULL) {
        printf("Empty Stack\n");
        return;
    }

    Node *temp = S->top;
    printf("----------\n");
    printf("Top-> |%d|\n", temp->data);
    temp = temp->next;
    
    while(temp) {
        printf("      |%d|\n", temp->data);
        temp = temp->next;
    }
    printf("----------\n");
}

void push(Stack *S, int val) {
    Node *newNode = createNode(val);

    if(newNode == NULL) return;

    if(S->top == NULL) {
        S->top = newNode;
    } else {
        newNode->next = S->top;
        S->top = newNode;
    }

    S->getSize++;
}

void pop(Stack *S) {
    if(S->top == NULL) {
        printf("Stack Underflow\n");
        return;
    }

    Node *temp = S->top;
    S->top = temp->next;
    free(temp);
    S->getSize--;
}

int getSize(Stack *S) {
    return S->getSize;
}

int top(Stack *S) {
    if(S->top == NULL) {
        printf("Empty Stack\n");
        return -1;
    }
    return S->top->data;
}

int search(Stack *S, int target) {
    Node *temp = S->top;
    int pos = 0;

    while(temp) {
        if(temp->data == target) {
            return pos;
        }
        pos++;
        temp = temp->next;
    }

    printf("Not found\n");
    return -1;
}

void freeStack(Stack *S) {
    while(S->top) {
        Node *temp = S->top;
        S->top = S->top->next;
        free(temp);
    }
    S->getSize = 0;
}

void reverseArray(int arr[], int n) {
    Stack reverse;
    initStack(&reverse);

    for(int i = 0; i<n; i++) {
        push(&reverse, arr[i]);
    }

    for(int i = 0; i<n; i++) {
        arr[i] = top(&reverse);
        pop(&reverse);
    }
    
    freeStack(&reverse);
}

