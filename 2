#include<stdio.h>

// coeff - a0, a1, a2.. 
// exp - n, n-1,..


void printPolynomial(int pol[][2], int rows) {
    for(int i = 0; i<rows; i++) {
        printf("(");
        for(int j = 0; j<2; j++) {
            printf("%d",pol[i][j]);
            if(j==0) printf(",");
        }
            printf("), ");
    }
    printf("\n");
}

void addPolynomial(int polA[][2], int polB[][2], int rowsA, int rowsB) {
    int rowsC = rowsA+rowsB;
    int polC[rowsC][2];   
    int i = 0, j = 0, k = 0;

    while(i < rowsA && j < rowsB) {
        if(polA[i][1] == polB[j][1]) {
            polC[k][0] = polA[i][0] + polB[j][0];
            polC[k][1] = polA[i][1];
            i++;
            j++;
        }
        else if(polA[i][1] > polB[j][1]) {
            polC[k][0] = polA[i][0];
            polC[k][1] = polA[i][1];
            i++;
        }
        else {
            polC[k][0] = polB[j][0];
            polC[k][1] = polB[j][1];
            j++;
        }
        k++;
    }

    while(i < rowsA) {
        polC[k][0] = polA[i][0];
        polC[k][1] = polA[i][1];
        i++;
        k++;
    }

    while(j < rowsB) {
        polC[k][0] = polB[j][0];
        polC[k][1] = polB[j][1];
        j++;
        k++;
    }

    for(int i = 0; i < k; i++) {
        printf("(%d,%d) ", polC[i][0], polC[i][1]);
    }
    printf("\n");
}

void multiplyPolynomial(int polA[][2], int polB[][2], int rowsA, int rowsB) {

    int rowsC = rowsA * rowsB;
    int polC[rowsC][2];
    int k = 0;

    for(int i = 0; i < rowsA; i++) {
        for(int j = 0; j < rowsB; j++) {

            polC[k][0] = polA[i][0] * polB[j][0];          
            polC[k][1] = polA[i][1] + polB[j][1];          
            k++;
        }
    }

    for(int i = 0; i < k; i++) {
        for(int j = i + 1; j < k; j++) {

            if(polC[i][1] == polC[j][1]) {

                polC[i][0] += polC[j][0];   
                polC[j][0] = 0;             
            }
        }
    }

    for(int i = 0; i < k; i++) {
        if(polC[i][0] != 0) {
            printf("(%d,%d) ", polC[i][0], polC[i][1]);
        }
    }

    printf("\n");
}

int main() {
    int polA[3][2] = {{8,3},{4,2},{3,1}};
    int polB[3][2] = {{6,3},{5,2},{7,1}};

    int rowsA = sizeof(polA) / sizeof(polA[0]);
    int rowsB = sizeof(polB) / sizeof(polB[0]);
    
    printf("Polynomial A: ");
    printPolynomial(polA, rowsA);

    printf("Polynomial B: ");
    printPolynomial(polB, rowsB);

    printf("Addition: ");
    addPolynomial(polA, polB, rowsA, rowsB);
    
    printf("Multiplication: ");
    multiplyPolynomial(polA, polB, rowsA, rowsB);
    return 0;
}
